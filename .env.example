# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Razorpay — https://dashboard.razorpay.com/app/keys (use Test keys for development)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Session signing — generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_a_long_random_string

# Public app URL (password reset emails, production deployments)
NEXT_PUBLIC_APP_URL=http://localhost:3000
