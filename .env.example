# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# ─── Vercel (frontend) ───
# Your Render backend URL — no trailing slash
# IMPORTANT: For checkout/auth to work reliably, either:
#   (A) Set NEXT_PUBLIC_USE_SAME_ORIGIN_API=true and add DATABASE_URL + AUTH_SECRET on Vercel (recommended), OR
#   (B) Use custom domains with COOKIE_DOMAIN=.yourdomain.com on Render
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
# NEXT_PUBLIC_USE_SAME_ORIGIN_API=true
# Your Vercel site URL
NEXT_PUBLIC_APP_URL=https://your-frontend.vercel.app
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ─── Render (backend) ───
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres
# AUTH_SECRET=replace_with_a_long_random_string
# RAZORPAY_KEY_SECRET=your_razorpay_secret_here
# FRONTEND_URL=https://your-frontend.vercel.app
# COOKIE_DOMAIN=.medlivehealthcare.com
# NEXT_PUBLIC_APP_URL=https://your-frontend.vercel.app

# ─── Local development (monolith — leave NEXT_PUBLIC_API_URL empty) ───
# AUTH_SECRET=replace_with_a_long_random_string
# DATABASE_URL=postgresql://...
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_secret_here
# NEXT_PUBLIC_APP_URL=http://localhost:3000
